{
  "hosting": {
    "site": "vbc-protocol",
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/app",    "destination": "/vbc-app.html" },
      { "source": "/app/**", "destination": "/vbc-app.html" },
      { "source": "**",      "destination": "/index.html"   }
    ]
  }
}
